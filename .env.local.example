# =============================================================================
# AUTHENTICATION - WorkOS (Required)
# =============================================================================
# Sign up at: https://workos.com/
WORKOS_API_KEY=sk_example_123456789

# ⚠️ IMPORTANT: Also add this to Convex Dashboard → Environment Variables
WORKOS_CLIENT_ID=client_123456789

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
WORKOS_COOKIE_PASSWORD=
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback

# WorkOS Dashboard → Webhooks → Endpoint signing secret
WORKOS_WEBHOOK_SECRET=

# =============================================================================
# CONVEX DATABASE (Required)
# =============================================================================
# Run `npx convex dev` first to generate these values
CONVEX_DEPLOYMENT=dev:your-deployment-name
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ⚠️ IMPORTANT: Also add this to Convex Dashboard → Environment Variables
CONVEX_SERVICE_ROLE_KEY="replace-with-a-32+char-random-secret"

# For local Convex deployment, use `pnpm run dev:local` instead of `pnpm run dev`
# See: https://docs.convex.dev/cli/local-deployments

# =============================================================================
# S3 FILE STORAGE (Optional - Feature Flag Controlled)
# =============================================================================
# AWS S3 credentials for file storage (only needed if S3 is enabled)
# Sign up at: https://aws.amazon.com/s3/
# ⚠️ IMPORTANT: If using S3, also add these to Convex Dashboard → Environment Variables
AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=
AWS_S3_REGION=us-east-1
AWS_S3_BUCKET_NAME=

# Optional S3 configuration (defaults shown, uncomment to override)
# S3_URL_LIFETIME_SECONDS=3600
# S3_URL_EXPIRATION_BUFFER_SECONDS=300

# =============================================================================
# AI PROVIDER CONFIGURATION
# =============================================================================
# Provider Mode: openrouter | openai | google | anthropic | ollama
# - openrouter: Unified cloud provider (default, recommended)
# - openai: Direct OpenAI API
# - google: Direct Google Gemini API
# - anthropic: Direct Anthropic Claude API
# - ollama: Local Ollama instance (Qwen, DeepSeek, Mistral, Llama)
# Primary production routing:
# - Agent primary: Anthropic Claude Sonnet
# - Agent secondary: OpenAI GPT-4.5
# - Research/analysis: Google Gemini
PROVIDER_MODE=openrouter

# ---------------------------------------------------------------------------
# OpenRouter (Default Cloud Provider)
# ---------------------------------------------------------------------------
# Get key at: https://openrouter.ai/
OPENROUTER_API_KEY=

# ---------------------------------------------------------------------------
# OpenAI (Direct)
# ---------------------------------------------------------------------------
# Get key at: https://platform.openai.com/
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Google Gemini (Direct)
# ---------------------------------------------------------------------------
# Get key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
# Backward-compatible alias used by older deployments; leave blank unless needed.
GOOGLE_GENERATIVE_AI_API_KEY=

# ---------------------------------------------------------------------------
# Anthropic Claude (Direct)
# ---------------------------------------------------------------------------
# Get key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Ollama (Local Mode)
# ---------------------------------------------------------------------------
# Install Ollama: https://ollama.com/
# Run local models: ollama run qwen2.5-coder
# Prepared local placeholders only; not active unless PROVIDER_MODE=ollama.
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434/api
QWEN_MODEL=
DEEPSEEK_MODEL=
MISTRAL_MODEL=
LLAMA_MODEL=

# =============================================================================
# CODE EXECUTION - E2B (Required for Agent Mode)
# =============================================================================
# Sign up at: https://e2b.dev/
E2B_API_KEY=
E2B_TEMPLATE=terminal-agent-sandbox

# =============================================================================
# WEB SEARCH & SCRAPING (Optional)
# =============================================================================
# Web Search API - https://docs.perplexity.ai/guides/search-quickstart
# PERPLEXITY_API_KEY=

# Jina AI - URL content extraction: https://jina.ai/reader
# JINA_API_KEY=

# =============================================================================
# REDIS (Optional - for stream resumption)
# =============================================================================
# ⚠️ IMPORTANT: Also add this to Convex Dashboard → Environment Variables
# REDIS_URL=redis://localhost:6379

# =============================================================================
# RATE LIMITING (Optional - Upstash Redis)
# =============================================================================
# Sign up at: https://upstash.com/
# UPSTASH_REDIS_REST_URL=https://your-endpoint.upstash.io
# UPSTASH_REDIS_REST_TOKEN=

# =============================================================================
# FEATURE FLAGS (Optional)
# =============================================================================
# Cross-tab token sharing - coordinates auth token refresh across browser tabs
# to prevent WorkOS rate limits. Value is rollout percentage (0-100).
# NEXT_PUBLIC_FF_CROSS_TAB_TOKEN_SHARING=0

# =============================================================================
# REFERRALS (Optional)
# =============================================================================
# REFERRAL_PROGRAM_ENABLED=true
# REFERRAL_REFERRER_REWARD_DOLLARS=10
# REFERRAL_REFERRED_SIGNUP_BONUS_UNITS=10
# REFERRAL_ATTRIBUTION_MAX_USER_AGE_DAYS=7
# REFERRAL_COOKIE_MAX_AGE_DAYS=30

# =============================================================================
# ANALYTICS & OBSERVABILITY (Optional - PostHog)
# =============================================================================
# Sign up at: https://posthog.com/
# Used for product analytics, tool-call events, and server error tracking.
# NEXT_PUBLIC_POSTHOG_KEY=phc_
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
# NEXT_PUBLIC_POSTHOG_TRACK_FREE_USERS=true

# =============================================================================
# PAYMENTS (Optional - Stripe)
# =============================================================================
# Sign up at: https://stripe.com/
# ⚠️ IMPORTANT: If using Stripe, also add these to Convex Dashboard → Environment Variables
# STRIPE_API_KEY=sk_test_
# STRIPE_EXTRA_USAGE_WEBHOOK_SECRET=
# STRIPE_FRAUD_WEBHOOK_SECRET=
# STRIPE_SUBSCRIPTION_WEBHOOK_SECRET=

# =============================================================================
# BASE URL (Required)
# =============================================================================
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# =============================================================================
# CENTRIFUGO (Real-time sandbox relay)
# =============================================================================
CENTRIFUGO_TOKEN_SECRET=
CENTRIFUGO_WS_URL=ws://localhost:8000/connection/websocket

# =============================================================================
# TRIGGER.DEV (Required for "Agent Long" mode)
# =============================================================================
# Sign up at: https://trigger.dev/  →  API Keys page  →  copy `tr_dev_…`.
# Task-side env vars live in the Trigger.dev dashboard, not here.
TRIGGER_PROJECT_ID=proj_
TRIGGER_SECRET_KEY=tr_dev_
