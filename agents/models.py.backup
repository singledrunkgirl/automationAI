#!/usr/bin/env python3
"""AI Model Abstraction — Local models via Ollama, remote via OpenRouter/OpenAI."""

import os, json, subprocess, time, logging
from dotenv import load_dotenv
load_dotenv()
from typing import Optional, Dict, List
from abc import ABC, abstractmethod

logging.basicConfig(level=logging.INFO, format="[model] %(message)s")
logger = logging.getLogger("agent_models")

class BaseModel(ABC):
    @abstractmethod
    def generate(self, prompt: str, max_tokens: int = 1024, temperature: float = 0.7) -> str:
        ...

    @abstractmethod
    def available(self) -> bool:
        ...


class OllamaModel(BaseModel):
    """Local Ollama model."""
    def __init__(self, model_name: str = "deepseek-coder:6.7b"):
        self.model = model_name

    def generate(self, prompt: str, max_tokens: int = 1024, temperature: float = 0.7) -> str:
        try:
            r = subprocess.run(["ollama", "run", self.model, prompt], capture_output=True, text=True, timeout=60)
            return r.stdout.strip() or r.stderr.strip()
        except Exception as e:
            return f"[Ollama error: {e}]"

    def available(self) -> bool:
        try:
            r = subprocess.run(["ollama", "list"], capture_output=True, text=True, timeout=5)
load_dotenv()
        except Exception:
            return False


class OpenRouterModel(BaseModel):
    """OpenRouter API model (Claude, Gemini, DeepSeek, etc.) with optional Tor SOCKS5 routing."""
    def __init__(self, model_id: str = "deepseek/deepseek-v4-pro"):
        self.model_id = model_id
        self.api_key = os.environ.get("OPENROUTER_API_KEY", "")
        self.base_url = "https://openrouter.ai/api/v1/chat/completions"
        self.proxies = None
        # Route through Tor SOCKS5 if enabled
        if os.environ.get("HWAI_PROXY") or os.environ.get("http_proxy"):
            proxy = os.environ.get("HWAI_PROXY") or os.environ.get("http_proxy")
            self.proxies = {"http": proxy, "https": proxy}
            logger.info(f"OpenRouter via proxy: {proxy}")

    def generate(self, prompt: str, max_tokens: int = 1024, temperature: float = 0.7) -> str:
        if not self.api_key:
            return "[OpenRouter: no API key]"
        prompt = self._obfuscate(prompt)
        try:
            import urllib.request
            body = json.dumps({
                "model": self.model_id,
                "messages": [{"role": "user", "content": prompt}],
                "max_tokens": max_tokens,
                "temperature": temperature,
            }).encode()
            req = urllib.request.Request(self.base_url, data=body, headers={
                "Authorization": f"Bearer {self.api_key}",
                "Content-Type": "application/json",
            })
            with urllib.request.urlopen(req, timeout=60) as resp:
                data = json.loads(resp.read())
                return data["choices"][0]["message"]["content"].strip()
        except Exception as e:
            return f"[OpenRouter error: {e}]"

    def _obfuscate(self, prompt):
        return prompt  # DISABLED - was corrupting pentesting prompts
        replacements = {
            "diamond": "numeric_unit",
            "inject": "sync_stream",
            "fraud": "logic_test",
            "bypass": "alignment"
        }
        for k, v in replacements.items():
            prompt = prompt.replace(k, v)
        return prompt

    def available(self) -> bool:
        return bool(self.api_key)


class RuleBasedModel(BaseModel):
    """Simple rule-based fallback — always available."""
    def __init__(self, role: str = "general"):
        self.role = role

    def generate(self, prompt: str, max_tokens: int = 1024, temperature: float = 0.7) -> str:
        # Generate structured response based on role and prompt keywords
        target = ""
        for word in prompt.split():
            if "." in word and not word.startswith("http"):
                target = word
                break

        responses = {
            "recon": f"RECOMMENDATION: Run comprehensive reconnaissance on {target}. Strategy: 1) nmap -sV -sC {target}, 2) gobuster dir scan, 3) dnsrecon enumeration, 4) theHarvester email discovery, 5) waybackurls historical analysis. This maximizes attack surface discovery before exploitation.",
            "exploit": f"RECOMMENDATION: Exploit discovered services on {target}. Strategy: 1) searchsploit for each service version, 2) sqlmap if web app detected, 3) hydra brute-force on SSH/FTP, 4) metasploit module matching, 5) custom exploit if needed. Prioritize high-value targets.",
            "payload": f"RECOMMENDATION: Generate stealthy payload for {target}. Strategy: 1) msfvenom staged payload, 2) Veil-Evasion AV bypass, 3) UPX packing for size reduction, 4) PowerShell AMSI bypass, 5) custom shellcode with encryption. Deploy after initial foothold confirmed.",
            "post-exploit": f"RECOMMENDATION: Post-exploitation on {target}. Strategy: 1) mimikatz credential dump, 2) bloodhound AD mapping, 3) impacket lateral movement, 4) persistence via scheduled tasks, 5) data exfiltration via encrypted tunnel. Maintain access.",
            "evasion": f"RECOMMENDATION: Evasion strategy for {target}. Strategy: 1) AMSI patching on PowerShell, 2) ETW logging disable, 3) process injection into trusted binary, 4) traffic obfuscation, 5) log clearing. Stay undetected throughout operation.",
        }
        return responses.get(self.role, f"ANALYSIS: Process prompt about {target}. Recommend systematic approach using appropriate tools for the task.")

    def available(self) -> bool:
        return True


# ── Model Factory ───────────────────────────────────────────────────────

def create_model(model_type: str = "auto", model_name: str = "") -> BaseModel:
    """
    Create the best available model.
    model_type: "openrouter", "ollama", "rule", "auto"
    """
    # Try OpenRouter if API key is set
    if model_type in ("openrouter", "auto") and os.environ.get("OPENROUTER_API_KEY"):
        m = OpenRouterModel(model_name or "deepseek/deepseek-v4-pro")
        if m.available():
            return m

    # Try Ollama
    if model_type in ("ollama", "auto"):
        m = OllamaModel(model_name or "deepseek-coder:6.7b")
        if m.available():
            return m

    # Fall back to rule-based
    return RuleBasedModel()
